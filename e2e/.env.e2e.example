# Copiar este archivo a "e2e/.env.e2e" (sin el ".example") y completar con datos reales.
# "e2e/.env.e2e" esta ignorado por git (ver .gitignore en la raiz) - nunca commitear credenciales.

# URL de la SPA corriendo en local. Default si no se define: http://localhost:8080
E2E_BASE_URL=http://localhost:8080

# Credenciales de un usuario de prueba (owner) sembrado por el fixture del prompt 613.
# El login de empresa-spa es por "Numero de documento" (doc_number), no por email real,
# pero se mantiene el nombre E2E_EMAIL para que el harness sea consistente con otros
# proyectos del workspace que si loguean por email.
E2E_EMAIL=
E2E_PASSWORD=
